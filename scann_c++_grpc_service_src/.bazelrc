# .bazelrc
#  Force the use of local JDK instead of downloading remote ones
build --java_runtime_version=local_jdk
#build --javabase=@local_jdk//:jdk

#  Strict toolchain resolution (prevents auto-fetching "everything")
build --incompatible_enable_cc_toolchain_resolution

#  Restrict platforms to the current host
# This tells Bazel: "I am only building for the machine I am on."
build --platforms=@local_config_platform//:host

# Disable specific rules if possible (Optional but aggressive)
# If you are strictly doing C++, you can try to keep Go/Java/Rust 
# from being fully configured, though this depends on your build targets
build --define=grpc_no_xds=true

#  Debugging flags (Useful to see WHAT is forcing a download)
# Remove this later; it's too noisy for daily use
# build --toolchain_resolution_debug=.*
